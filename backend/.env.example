# =============================================================
# CMMS - Variables de entorno
# Copiar este archivo a .env y completar con valores reales
# NUNCA subir .env a GitHub
# =============================================================

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cmms_db
DB_USER=cmms_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# JWT - Autenticación
# Generar con: openssl rand -hex 32
SECRET_KEY=GENERAR_CON_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App
APP_NAME=CMMS IMCLA-Volcán
APP_VERSION=1.0.0
DEBUG=False
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Archivos subidos
UPLOAD_DIR=/var/www/cmms/uploads
MAX_FILE_SIZE_MB=10

# Email (para notificaciones - opcional fase 1)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
